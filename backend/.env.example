# ══════════════════════════════════════════════════════════════
# SMAR-IA — Variables de Entorno
# Copiar este archivo como .env y ajustar los valores
# ══════════════════════════════════════════════════════════════

# ── Seguridad (OBLIGATORIO cambiar en producción) ────────────
SMAR_IA_SECRET_KEY=cambiar_por_clave_segura_de_64_caracteres_minimo
SMAR_IA_ALGORITHM=HS256
SMAR_IA_TOKEN_EXPIRE_MINUTES=1440

# ── Modelo ML ────────────────────────────────────────────────
# SMAR_IA_MODELS_DIR=../ml_pipeline/models
# SMAR_IA_NUM_FEATURES=80

# ── Umbrales de Decisión ─────────────────────────────────────
SMAR_IA_AUTO_BLOCK_THRESHOLD=0.95
SMAR_IA_SUSPICIOUS_ALERT_COUNT=3
SMAR_IA_SUSPICIOUS_WINDOW_MINUTES=5

# ── Modo de operación ────────────────────────────────────────
# true = solo registra alertas sin bloquear (modo observación)
SMAR_IA_DRY_RUN=false

# ── Base de Datos ────────────────────────────────────────────
# SMAR_IA_SECURITY_DB=sqlite:///./security_logs.db
# SMAR_IA_TRAFFIC_DB=sqlite:///./traffic.db
