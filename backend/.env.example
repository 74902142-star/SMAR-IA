# ══════════════════════════════════════════════════════════════
# SMAR-IA — Variables de Entorno
# Copiar este archivo como .env y ajustar los valores
# ══════════════════════════════════════════════════════════════

# ── Seguridad (OBLIGATORIO cambiar en producción) ────────────
SMAR_IA_SECRET_KEY=cambiar_por_clave_segura_de_64_caracteres_minimo
SMAR_IA_ALGORITHM=HS256
SMAR_IA_TOKEN_EXPIRE_MINUTES=1440

# ── Modelo ML ────────────────────────────────────────────────
# SMAR_IA_MODELS_DIR=../ml_pipeline/models
# SMAR_IA_NUM_FEATURES=80

# ── Umbrales de Decisión ─────────────────────────────────────
SMAR_IA_AUTO_BLOCK_THRESHOLD=0.95
SMAR_IA_SUSPICIOUS_ALERT_COUNT=3
SMAR_IA_SUSPICIOUS_WINDOW_MINUTES=5

# ── Modo de operación ────────────────────────────────────────
# false = bloqueo real con iptables (requiere sudo)
# true  = solo registra alertas sin bloquear (modo observación)
SMAR_IA_DRY_RUN=false

# ── Alertas externas ─────────────────────────────────────────
# Slack Webhook URL
# SMAR_IA_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Discord Webhook URL
# SMAR_IA_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Webhook genérico
# SMAR_IA_WEBHOOK_URL=https://hooks.example.com/...
# Email (SMTP)
# SMAR_IA_SMTP_HOST=smtp.gmail.com
# SMAR_IA_SMTP_PORT=587
# SMAR_IA_SMTP_USER=tu-correo@gmail.com
# SMAR_IA_SMTP_PASS=tu-contraseña
# SMAR_IA_SMTP_FROM=smar-ia@localhost
# SMAR_IA_EMAIL_TO=admin@example.com

# ── Base de Datos ────────────────────────────────────────────
# Para SQLite (desarrollo):
SMAR_IA_SECURITY_DB=sqlite:///./security_logs.db
SMAR_IA_TRAFFIC_DB=sqlite:///./traffic.db
# Para PostgreSQL (producción):
# SMAR_IA_SECURITY_DB=postgresql://user:pass@localhost:5432/smaria_security
# SMAR_IA_TRAFFIC_DB=postgresql://user:pass@localhost:5432/smaria_traffic
# SMAR_IA_DB_POOL_SIZE=5
# SMAR_IA_DB_MAX_OVERFLOW=10

# ── Firewall Backend ─────────────────────────────────────────
# auto = detecta automáticamente (iptables > nftables)
# iptables = usa iptables clásico
# nftables = usa nftables moderno
# SMAR_IA_FIREWALL_BACKEND=auto

# ── Bloqueo Progresivo (fail2ban-style) ──────────────────────
# SMAR_IA_PROGRESSIVE_BLOCK=true
# SMAR_IA_PROGRESSIVE_INTERVALS=5,30,1440  # minutos: 1er, 2do, 3er+

# ── SIEM (Syslog) ───────────────────────────────────────────
# SMAR_IA_SIEM_SYSLOG=false
# SMAR_IA_SIEM_SYSLOG_HOST=127.0.0.1
# SMAR_IA_SIEM_SYSLOG_PORT=514

# ── Threat Intelligence ──────────────────────────────────────
# SMAR_IA_THREAT_INTEL=true
# SMAR_IA_THREAT_INTEL_UPDATE=60  # minutos entre actualizaciones
# SMAR_IA_THREAT_INTEL_FEEDS=https://feeds.dshield.org/block.txt,https://rules.emergingthreats.net/blockrules/compromised-ips.txt

# ── Honeypot ────────────────────────────────────────────────
# SMAR_IA_HONEYPOT=false
# SMAR_IA_HONEYPOT_PORTS=22,3306,8080,8443

# ── Prometheus ──────────────────────────────────────────────
# SMAR_IA_PROMETHEUS=true

# ── Rate Limiting Interno ───────────────────────────────────
# SMAR_IA_RATE_LIMIT_ALERTS=10   # eventos por ventana
# SMAR_IA_RATE_LIMIT_WINDOW=60   # ventana en segundos
