# SMAR-IA — Variables de Entorno
# Copiar a .env y ajustar valores

# ── JWT (OBLIGATORIO en producción) ──
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SMAR_IA_SECRET_KEY=

# ── Admin inicial ──
# Si no se define, se usa 'admin123' con advertencia
SMAR_IA_ADMIN_PASSWORD=

# ── CORS ──
SMAR_IA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT ──
SMAR_IA_ALGORITHM=HS256
SMAR_IA_TOKEN_EXPIRE_MINUTES=1440

# ── ML Model ──
SMAR_IA_MODELS_DIR=../ml_pipeline/models
SMAR_IA_NUM_FEATURES=80

# ── Thresholds ──
SMAR_IA_AUTO_BLOCK_THRESHOLD=0.85
SMAR_IA_SUSPICIOUS_ALERT_COUNT=3
SMAR_IA_SUSPICIOUS_WINDOW_MINUTES=5

# ── Mode ──
SMAR_IA_DRY_RUN=true

# ── Databases ──
SMAR_IA_SECURITY_DB=sqlite:///./security_logs.db
SMAR_IA_TRAFFIC_DB=sqlite:///./traffic.db
